# Google Gemini API key (used by Vision Agents SDK)
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your_gemini_api_key_here"

# Stream Video SDK keys (required for WebRTC transport)
# Get keys from https://getstream.io/dashboard/
STREAM_API_KEY="your_stream_api_key"
STREAM_API_SECRET="your_stream_api_secret"

# Server config
HOST="0.0.0.0"
PORT="8080"
