# Google Gemini API Key
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# VITE_ prefix is required for Vite to expose this to the browser bundle
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# Also used by the Python backend (Vision Agents SDK reads GOOGLE_API_KEY)
GOOGLE_API_KEY="your_gemini_api_key_here"

# Stream Video SDK (required for Vision Agents WebRTC transport)
# Get keys from https://getstream.io/dashboard/
VITE_STREAM_API_KEY="your_stream_api_key"
STREAM_API_KEY="your_stream_api_key"

# Note: Backend often expects STREAM_API_SECRET
STREAM_SECRET_KEY="your_stream_api_secret"

# Agent backend URL (frontend → backend)
VITE_AGENT_URL="http://localhost:8080"

# Application hosting URL (optional, used in some deployment scenarios)
APP_URL="http://localhost:3000"
